{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "description": "Deploy LibreChat application to Azure App Service with MongoDB"
    },
    "parameters": {
        "siteName": {
            "type": "string",
            "defaultValue": "librechat-app",
            "metadata": {
                "description": "Name of the Azure Web App"
            }
        },
        "hostingPlanName": {
            "type": "string",
            "defaultValue": "librechat-plan",
            "metadata": {
                "description": "Name of the App Service Plan"
            }
        },
        "sku": {
            "type": "string",
            "allowedValues": [
                "B1",
                "B2", 
                "B3",
                "S1",
                "S2",
                "S3",
                "P1v2",
                "P2v2",
                "P3v2"
            ],
            "defaultValue": "B2",
            "metadata": {
                "description": "The pricing tier for the hosting plan"
            }
        },
        "cosmosDBAccountName": {
            "type": "string",
            "defaultValue": "librechat-cosmosdb",
            "metadata": {
                "description": "Name of the Cosmos DB account (MongoDB API)"
            }
        },
        "cosmosDBDatabaseName": {
            "type": "string",
            "defaultValue": "LibreChat",
            "metadata": {
                "description": "Name of the MongoDB database"
            }
        },
        "storageAccountName": {
            "type": "string",
            "defaultValue": "[concat('librechatsa', uniqueString(resourceGroup().id))]",
            "metadata": {
                "description": "Name of the storage account for file uploads"
            }
        },
        "location": {
            "type": "string",
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Location for all resources"
            }
        },
        "repoUrl": {
            "type": "string",
            "defaultValue": "https://github.com/v-khdumi/LibreChat.git",
            "metadata": {
                "description": "GitHub repository URL"
            }
        },
        "branch": {
            "type": "string",
            "defaultValue": "main",
            "metadata": {
                "description": "GitHub branch to deploy"
            }
        }
    },
    "variables": {
        "cosmosDBConnectionString": "[concat('mongodb://', parameters('cosmosDBAccountName'), ':', listKeys(resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosDBAccountName')), '2021-04-15').primaryMasterKey, '@', parameters('cosmosDBAccountName'), '.mongo.cosmos.azure.com:10255/', parameters('cosmosDBDatabaseName'), '?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@', parameters('cosmosDBAccountName'), '@')]",
        "storageConnectionString": "[concat('DefaultEndpointsProtocol=https;AccountName=', parameters('storageAccountName'), ';EndpointSuffix=core.windows.net;AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), '2021-04-01').keys[0].value)]"
    },
    "resources": [
        {
            "type": "Microsoft.Web/serverfarms",
            "apiVersion": "2021-02-01",
            "name": "[parameters('hostingPlanName')]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "[parameters('sku')]"
            },
            "kind": "linux",
            "properties": {
                "reserved": true
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2021-04-01",
            "name": "[parameters('storageAccountName')]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "Standard_LRS"
            },
            "kind": "StorageV2",
            "properties": {
                "accessTier": "Hot",
                "supportsHttpsTrafficOnly": true,
                "minimumTlsVersion": "TLS1_2"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices",
            "apiVersion": "2021-04-01",
            "name": "[concat(parameters('storageAccountName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
            ]
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
            "apiVersion": "2021-04-01",
            "name": "[concat(parameters('storageAccountName'), '/default/uploads')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices', parameters('storageAccountName'), 'default')]"
            ],
            "properties": {
                "publicAccess": "None"
            }
        },
        {
            "type": "Microsoft.DocumentDB/databaseAccounts",
            "apiVersion": "2021-04-15",
            "name": "[parameters('cosmosDBAccountName')]",
            "location": "[parameters('location')]",
            "kind": "MongoDB",
            "properties": {
                "databaseAccountOfferType": "Standard",
                "consistencyPolicy": {
                    "defaultConsistencyLevel": "Session"
                },
                "locations": [
                    {
                        "locationName": "[parameters('location')]",
                        "failoverPriority": 0,
                        "isZoneRedundant": false
                    }
                ],
                "capabilities": [
                    {
                        "name": "EnableMongo"
                    }
                ],
                "apiProperties": {
                    "serverVersion": "4.2"
                }
            }
        },
        {
            "type": "Microsoft.DocumentDB/databaseAccounts/mongodbDatabases",
            "apiVersion": "2021-04-15",
            "name": "[concat(parameters('cosmosDBAccountName'), '/', parameters('cosmosDBDatabaseName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosDBAccountName'))]"
            ],
            "properties": {
                "resource": {
                    "id": "[parameters('cosmosDBDatabaseName')]"
                },
                "options": {
                    "throughput": 400
                }
            }
        },
        {
            "type": "Microsoft.Web/sites",
            "apiVersion": "2021-02-01",
            "name": "[parameters('siteName')]",
            "location": "[parameters('location')]",
            "dependsOn": [
                "[resourceId('Microsoft.Web/serverfarms', parameters('hostingPlanName'))]",
                "[resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosDBAccountName'))]",
                "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
            ],
            "kind": "app,linux",
            "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('hostingPlanName'))]",
                "siteConfig": {
                    "linuxFxVersion": "NODE|20-lts",
                    "appCommandLine": "bash startup.sh",
                    "alwaysOn": true,
                    "ftpsState": "Disabled",
                    "minTlsVersion": "1.2",
                    "appSettings": [
                        {
                            "name": "NODE_ENV",
                            "value": "production"
                        },
                        {
                            "name": "MONGO_URI",
                            "value": "[variables('cosmosDBConnectionString')]"
                        },
                        {
                            "name": "HOST",
                            "value": "0.0.0.0"
                        },
                        {
                            "name": "PORT",
                            "value": "8080"
                        },
                        {
                            "name": "DOMAIN_CLIENT",
                            "value": "[concat('https://', parameters('siteName'), '.azurewebsites.net')]"
                        },
                        {
                            "name": "DOMAIN_SERVER",
                            "value": "[concat('https://', parameters('siteName'), '.azurewebsites.net')]"
                        },
                        {
                            "name": "AZURE_STORAGE_CONNECTION_STRING",
                            "value": "[variables('storageConnectionString')]"
                        },
                        {
                            "name": "AZURE_CONTAINER_NAME",
                            "value": "uploads"
                        },
                        {
                            "name": "FILE_STRATEGY",
                            "value": "azure"
                        },
                        {
                            "name": "CONSOLE_JSON",
                            "value": "true"
                        },
                        {
                            "name": "TRUST_PROXY",
                            "value": "1"
                        },
                        {
                            "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
                            "value": "true"
                        },
                        {
                            "name": "WEBSITE_NODE_DEFAULT_VERSION",
                            "value": "20.11.1"
                        }
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Web/sites/sourcecontrols",
            "apiVersion": "2021-02-01",
            "name": "[concat(parameters('siteName'), '/web')]",
            "dependsOn": [
                "[resourceId('Microsoft.Web/sites', parameters('siteName'))]"
            ],
            "properties": {
                "repoUrl": "[parameters('repoUrl')]",
                "branch": "[parameters('branch')]",
                "isManualIntegration": true
            }
        }
    ],
    "outputs": {
        "webAppUrl": {
            "type": "string",
            "value": "[concat('https://', parameters('siteName'), '.azurewebsites.net')]"
        },
        "mongoConnectionString": {
            "type": "string",
            "value": "[variables('cosmosDBConnectionString')]"
        }
    }
}